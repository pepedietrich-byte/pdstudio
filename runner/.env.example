# PDSTUDIO Runner — Environment Variables
# Kopiere nach .env und fülle alle Werte aus.
# NIEMALS die echte .env committen.

# Bearer Secret für HTTP Auth — mindestens 32 zufällige Zeichen
# Generieren: openssl rand -hex 32
RUNNER_SECRET=

# Port auf dem der Runner lauscht
PORT=8787

# Absoluter Pfad zum geklonten GitHub Repo auf dem VPS
REPO_PATH=/var/www/pdstudio

# Vercel Personal Access Token (aus vercel.com/account/tokens)
VERCEL_TOKEN=

# GitHub Branch für Pull + Push
GITHUB_BRANCH=main

# GitHub Repo URL (SSH bevorzugt — SSH Key muss auf VPS + GitHub hinterlegt sein)
GITHUB_REPO=git@github.com:pepedietrich-byte/pdstudio.git

# Optional: HTTPS statt SSH (dann GITHUB_TOKEN nötig)
# GITHUB_PUSH_METHOD=https
# GITHUB_TOKEN=ghp_...

# Timeout in Millisekunden pro Run (Standard: 5 Minuten)
RUN_TIMEOUT_MS=300000

# Interner Pfad des Runners (normalerweise nicht ändern)
RUNNER_PATH=/opt/pdstudio-runner

# Claude Modell — default: Opus 4.7 (Claude Max Plan)
# Alternativen: claude-opus-4-8 (neueste), claude-sonnet-4-6, opus, sonnet, haiku
# Fast Mode (-/fast) ist headless aktuell nicht via CLI-Flag setzbar (v2.1.177)
CLAUDE_MODEL=claude-opus-4-7
